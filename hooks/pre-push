#!/usr/bin/env python3
"""
hooks/pre-push — Runs before every `git push`.

Reads configuration from .git/config [gt] (written by `gt init`).
If not configured, passes silently — `gt init` is the gate.

Blocks:
  1. Direct push to the protected branch  →  use `gt merge` instead
  2. Push of a branch that is behind origin/<protected>  →  run `gt sync` first

The env var GT_BYPASS_HOOK=1 allows `gt merge` to push through this hook.
"""
from __future__ import annotations

import os
import subprocess
import sys


def _run(cmd: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True,
    )


def _cfg(key: str) -> str | None:
    r = _run(["git", "config", "--local", f"gt.{key}"])
    v = r.stdout.strip()
    return v if r.returncode == 0 and v else None


def _load() -> tuple[str, str] | None:
    protected = _cfg("protected-branch")
    remote    = _cfg("remote")
    return (protected, remote) if protected and remote else None


def _branch(ref: str) -> str:
    return ref[len("refs/heads/"):] if ref.startswith("refs/heads/") else ref


def _is_behind(local_branch: str, remote: str, protected: str) -> bool:
    _run(["git", "fetch", remote, "--quiet"])
    r = _run([
        "git", "merge-base", "--is-ancestor",
        f"{remote}/{protected}", local_branch,
    ])
    return r.returncode != 0


def main() -> int:
    if os.environ.get("GT_BYPASS_HOOK") == "1":
        return 0

    config = _load()
    if config is None:
        return 0  # not configured — pass silently

    protected, remote = config
    errors: list[str] = []

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        parts = line.split()
        if len(parts) < 4:
            continue

        local_ref, local_sha, remote_ref, _ = parts[:4]

        if local_sha == "0" * 40:
            continue  # deletion push

        local_br  = _branch(local_ref)
        remote_br = _branch(remote_ref)

        if remote_br == protected:
            errors.append(
                f"Direct push to '{protected}' is not allowed.\n"
                f"   Use:  gt merge\n"
                f"   This runs simulation, confirmation, and creates a clean commit."
            )
            continue

        if local_br != protected:
            try:
                if _is_behind(local_br, remote, protected):
                    errors.append(
                        f"'{local_br}' is behind '{remote}/{protected}'.\n"
                        f"   Run:  gt sync  — then push again."
                    )
            except Exception:
                pass  # network errors are not a reason to block

    if errors:
        print("\n✖  pre-push blocked this push:\n", file=sys.stderr)
        for err in errors:
            for part in err.split("\n"):
                print(f"   {part}", file=sys.stderr)
            print(file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
